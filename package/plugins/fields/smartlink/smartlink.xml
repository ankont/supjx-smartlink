<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="fields" method="upgrade">
  <name>PLG_FIELDS_SMARTLINK</name>
  <author>SuperSoft</author>
  <creationDate>2026-02-28</creationDate>
  <copyright>(C) SuperSoft</copyright>
  <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
  <authorEmail>an_kont@yahoo.gr</authorEmail>
  <authorUrl>https://superor.wordpress.com</authorUrl>
  <element>smartlink</element>
  <version>1.12.3</version>
  <description>PLG_FIELDS_SMARTLINK_XML_DESCRIPTION</description>
  <namespace path="src">SuperSoft\Plugin\Fields\Smartlink</namespace>
  <files>
    <folder plugin="smartlink">services</folder>
    <folder>fields</folder>
    <folder>params</folder>
    <filename>smartlink.php</filename>
    <folder>layouts</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
  </files>
  <languages folder="language">
    <language tag="en-GB" client="administrator">en-GB/plg_fields_smartlink.ini</language>
    <language tag="en-GB" client="administrator">en-GB/plg_fields_smartlink.sys.ini</language>
    <language tag="el-GR" client="administrator">el-GR/plg_fields_smartlink.ini</language>
    <language tag="el-GR" client="administrator">el-GR/plg_fields_smartlink.sys.ini</language>
  </languages>
  <media destination="plg_fields_smartlink" folder="media">
    <filename>smartlink-content.css</filename>
    <filename>smartlink-content.js</filename>
    <filename>smartlink-builder.css</filename>
    <filename>smartlink-builder.js</filename>
    <filename>pickers.js</filename>
  </media>
  <config>
    <fields name="params">
      <fieldset name="basic" label="PLG_FIELDS_SMARTLINK_FIELDSET_BASIC">
        <field
          name="allowed_kinds"
          type="list"
          label="PLG_FIELDS_SMARTLINK_ALLOWED_KINDS_LABEL"
          description="PLG_FIELDS_SMARTLINK_ALLOWED_KINDS_DESC"
          multiple="true"
          filter="raw"
          default="external_url,anchor,email,phone,com_content_article,com_content_category,menu_item,com_tags_tag"
        >
          <option value="external_url">PLG_FIELDS_SMARTLINK_OPTION_KIND_EXTERNAL_URL</option>
          <option value="anchor">PLG_FIELDS_SMARTLINK_OPTION_KIND_ANCHOR</option>
          <option value="email">PLG_FIELDS_SMARTLINK_OPTION_KIND_EMAIL</option>
          <option value="phone">PLG_FIELDS_SMARTLINK_OPTION_KIND_PHONE</option>
          <option value="com_content_article">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTENT_ARTICLE</option>
          <option value="com_content_category">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTENT_CATEGORY</option>
          <option value="menu_item">PLG_FIELDS_SMARTLINK_OPTION_KIND_MENU_ITEM</option>
          <option value="com_tags_tag">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_TAGS_TAG</option>
          <option value="relative_url">PLG_FIELDS_SMARTLINK_OPTION_KIND_RELATIVE_URL</option>
          <option value="com_contact_contact">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTACT_CONTACT</option>
          <option value="user_profile">PLG_FIELDS_SMARTLINK_OPTION_KIND_USER_PROFILE</option>
          <option value="advanced_route">PLG_FIELDS_SMARTLINK_OPTION_KIND_ADVANCED_ROUTE</option>
          <option value="media_file">PLG_FIELDS_SMARTLINK_OPTION_KIND_MEDIA_FILE</option>
          <option value="image">PLG_FIELDS_SMARTLINK_OPTION_KIND_IMAGE</option>
          <option value="video">PLG_FIELDS_SMARTLINK_OPTION_KIND_VIDEO</option>
          <option value="gallery">PLG_FIELDS_SMARTLINK_OPTION_KIND_GALLERY</option>
        </field>
        <field
          name="allowed_actions"
          type="list"
          label="PLG_FIELDS_SMARTLINK_ALLOWED_ACTIONS_LABEL"
          description="PLG_FIELDS_SMARTLINK_ALLOWED_ACTIONS_DESC"
          multiple="true"
          filter="raw"
          default="no_action,link_open,link_download,preview_modal,toggle_view"
        >
          <option value="no_action">PLG_FIELDS_SMARTLINK_OPTION_ACTION_NO_ACTION</option>
          <option value="link_open">PLG_FIELDS_SMARTLINK_OPTION_ACTION_LINK_OPEN</option>
          <option value="link_download">PLG_FIELDS_SMARTLINK_OPTION_ACTION_LINK_DOWNLOAD</option>
          <option value="preview_modal">PLG_FIELDS_SMARTLINK_OPTION_ACTION_PREVIEW_MODAL</option>
          <option value="toggle_view">PLG_FIELDS_SMARTLINK_OPTION_ACTION_TOGGLE_VIEW</option>
        </field>
        <field
          name="default_kind"
          type="list"
          label="PLG_FIELDS_SMARTLINK_DEFAULT_KIND_LABEL"
          default="external_url"
        >
          <option value="external_url">PLG_FIELDS_SMARTLINK_OPTION_KIND_EXTERNAL_URL</option>
          <option value="anchor">PLG_FIELDS_SMARTLINK_OPTION_KIND_ANCHOR</option>
          <option value="email">PLG_FIELDS_SMARTLINK_OPTION_KIND_EMAIL</option>
          <option value="phone">PLG_FIELDS_SMARTLINK_OPTION_KIND_PHONE</option>
          <option value="com_content_article">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTENT_ARTICLE</option>
          <option value="com_content_category">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTENT_CATEGORY</option>
          <option value="menu_item">PLG_FIELDS_SMARTLINK_OPTION_KIND_MENU_ITEM</option>
          <option value="com_tags_tag">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_TAGS_TAG</option>
          <option value="relative_url">PLG_FIELDS_SMARTLINK_OPTION_KIND_RELATIVE_URL</option>
          <option value="com_contact_contact">PLG_FIELDS_SMARTLINK_OPTION_KIND_COM_CONTACT_CONTACT</option>
          <option value="user_profile">PLG_FIELDS_SMARTLINK_OPTION_KIND_USER_PROFILE</option>
          <option value="advanced_route">PLG_FIELDS_SMARTLINK_OPTION_KIND_ADVANCED_ROUTE</option>
          <option value="media_file">PLG_FIELDS_SMARTLINK_OPTION_KIND_MEDIA_FILE</option>
          <option value="image">PLG_FIELDS_SMARTLINK_OPTION_KIND_IMAGE</option>
          <option value="video">PLG_FIELDS_SMARTLINK_OPTION_KIND_VIDEO</option>
          <option value="gallery">PLG_FIELDS_SMARTLINK_OPTION_KIND_GALLERY</option>
        </field>
        <field
          name="default_action"
          type="list"
          label="PLG_FIELDS_SMARTLINK_DEFAULT_ACTION_LABEL"
          default="link_open"
        >
          <option value="no_action">PLG_FIELDS_SMARTLINK_OPTION_ACTION_NO_ACTION</option>
          <option value="link_open">PLG_FIELDS_SMARTLINK_OPTION_ACTION_LINK_OPEN</option>
          <option value="link_download">PLG_FIELDS_SMARTLINK_OPTION_ACTION_LINK_DOWNLOAD</option>
          <option value="preview_modal">PLG_FIELDS_SMARTLINK_OPTION_ACTION_PREVIEW_MODAL</option>
          <option value="toggle_view">PLG_FIELDS_SMARTLINK_OPTION_ACTION_TOGGLE_VIEW</option>
        </field>
        <field
          name="validation_profile"
          type="list"
          label="PLG_FIELDS_SMARTLINK_VALIDATION_PROFILE_LABEL"
          default="any"
        >
          <option value="any">PLG_FIELDS_SMARTLINK_OPTION_VALIDATION_ANY</option>
          <option value="images_only">PLG_FIELDS_SMARTLINK_OPTION_VALIDATION_IMAGES_ONLY</option>
          <option value="files_only">PLG_FIELDS_SMARTLINK_OPTION_VALIDATION_FILES_ONLY</option>
          <option value="youtube_only">PLG_FIELDS_SMARTLINK_OPTION_VALIDATION_YOUTUBE_ONLY</option>
          <option value="video_providers">PLG_FIELDS_SMARTLINK_OPTION_VALIDATION_VIDEO_PROVIDERS</option>
        </field>
        <field
          name="allow_external_media"
          type="radio"
          label="PLG_FIELDS_SMARTLINK_ALLOW_EXTERNAL_MEDIA_LABEL"
          default="1"
          class="btn-group btn-group-yesno"
          layout="joomla.form.field.radio.switcher"
        >
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field
          name="max_gallery_items"
          type="number"
          label="PLG_FIELDS_SMARTLINK_MAX_GALLERY_ITEMS_LABEL"
          default="12"
          min="1"
          max="50"
        />
        <field
          name="template_name"
          type="text"
          label="PLG_FIELDS_SMARTLINK_TEMPLATE_NAME_LABEL"
          description="PLG_FIELDS_SMARTLINK_TEMPLATE_NAME_DESC"
          filter="STRING"
        />
        <field
          name="use_smartlink_styles"
          type="radio"
          label="PLG_FIELDS_SMARTLINK_CONFIG_USE_STYLES_LABEL"
          description="PLG_FIELDS_SMARTLINK_CONFIG_USE_STYLES_DESC"
          default="1"
          class="btn-group btn-group-yesno"
          layout="joomla.form.field.radio.switcher"
        >
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field
          name="link_button_class"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_LINK_BUTTON_CLASS_LABEL"
          description="PLG_FIELDS_SMARTLINK_CONFIG_LINK_BUTTON_CLASS_DESC"
          default="smartlink-actionbtn"
          hint="smartlink-actionbtn"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="html_output_mode"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_HTML_OUTPUT_MODE_LABEL"
          description="PLG_FIELDS_SMARTLINK_CONFIG_HTML_OUTPUT_MODE_DESC"
          default="compact"
        >
          <option value="compact">PLG_FIELDS_SMARTLINK_CONFIG_HTML_OUTPUT_COMPACT</option>
          <option value="pretty">PLG_FIELDS_SMARTLINK_CONFIG_HTML_OUTPUT_PRETTY</option>
        </field>
        <field
          name="thumbnail_empty_mode"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_EMPTY_MODE_LABEL"
          default="generic"
        >
          <option value="empty">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_EMPTY_EMPTY</option>
          <option value="generic">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_EMPTY_GENERIC</option>
          <option value="specific">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_EMPTY_SPECIFIC</option>
        </field>
        <field
          name="thumbnail_empty_class"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_EMPTY_CLASS_LABEL"
          description="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_EMPTY_CLASS_DESC"
          hint="smartlink-image-empty"
          filter="string"
          showon="thumbnail_empty_mode:generic,specific"
        />
        <field
          name="thumbnail_position"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_POSITION_LABEL"
          default="inherit"
        >
          <option value="inherit">PLG_FIELDS_SMARTLINK_UI_KEEP_DEFAULTS</option>
          <option value="inline">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_POSITION_INLINE</option>
          <option value="top">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_POSITION_TOP</option>
          <option value="bottom">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_POSITION_BOTTOM</option>
          <option value="left">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_POSITION_LEFT</option>
          <option value="right">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_POSITION_RIGHT</option>
        </field>
        <field
          name="thumbnail_ratio"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_RATIO_LABEL"
          default="inherit"
        >
          <option value="inherit">PLG_FIELDS_SMARTLINK_UI_KEEP_DEFAULTS</option>
          <option value="auto">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_RATIO_AUTO</option>
          <option value="1-1">1:1</option>
          <option value="4-3">4:3</option>
          <option value="16-9">16:9</option>
        </field>
        <field
          name="thumbnail_fit"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_FIT_LABEL"
          default="inherit"
        >
          <option value="inherit">PLG_FIELDS_SMARTLINK_UI_KEEP_DEFAULTS</option>
          <option value="cover">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_FIT_COVER</option>
          <option value="contain">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_FIT_CONTAIN</option>
          <option value="fill">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_FIT_FILL</option>
          <option value="none">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_FIT_NONE</option>
          <option value="scale-down">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_FIT_SCALE_DOWN</option>
        </field>
        <field
          name="thumbnail_size"
          type="list"
          label="PLG_FIELDS_SMARTLINK_CONFIG_THUMBNAIL_SIZE_LABEL"
          default="inherit"
        >
          <option value="inherit">PLG_FIELDS_SMARTLINK_UI_KEEP_DEFAULTS</option>
          <option value="sm">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_SIZE_SMALL</option>
          <option value="md">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_SIZE_MEDIUM</option>
          <option value="lg">PLG_FIELDS_SMARTLINK_UI_THUMBNAIL_SIZE_LARGE</option>
        </field>
        <field
          name="thumbnail_position_class_inline"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_POSITION_CLASS_INLINE_LABEL"
          default="smartlink-thumb--inline"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_position_class_top"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_POSITION_CLASS_TOP_LABEL"
          default="smartlink-thumb--top"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_position_class_bottom"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_POSITION_CLASS_BOTTOM_LABEL"
          default="smartlink-thumb--bottom"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_position_class_left"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_POSITION_CLASS_LEFT_LABEL"
          default="smartlink-thumb--left"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_position_class_right"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_POSITION_CLASS_RIGHT_LABEL"
          default="smartlink-thumb--right"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_ratio_class_auto"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_RATIO_CLASS_AUTO_LABEL"
          default="smartlink-thumb--ratio-auto"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_ratio_class_1_1"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_RATIO_CLASS_1_1_LABEL"
          default="smartlink-thumb--ratio-1-1"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_ratio_class_4_3"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_RATIO_CLASS_4_3_LABEL"
          default="smartlink-thumb--ratio-4-3"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_ratio_class_16_9"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_RATIO_CLASS_16_9_LABEL"
          default="smartlink-thumb--ratio-16-9"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_fit_class_cover"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_FIT_CLASS_COVER_LABEL"
          default="smartlink-thumb--fit-cover"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_fit_class_contain"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_FIT_CLASS_CONTAIN_LABEL"
          default="smartlink-thumb--fit-contain"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_fit_class_fill"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_FIT_CLASS_FILL_LABEL"
          default="smartlink-thumb--fit-fill"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_fit_class_none"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_FIT_CLASS_NONE_LABEL"
          default="smartlink-thumb--fit-none"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_fit_class_scale_down"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_FIT_CLASS_SCALE_DOWN_LABEL"
          default="smartlink-thumb--fit-scale-down"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_size_class_sm"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_SIZE_CLASS_SM_LABEL"
          default="smartlink-thumb--sm"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_size_class_md"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_SIZE_CLASS_MD_LABEL"
          default="smartlink-thumb--md"
          filter="string"
          showon="use_smartlink_styles:0"
        />
        <field
          name="thumbnail_size_class_lg"
          type="text"
          label="PLG_FIELDS_SMARTLINK_CONFIG_SIZE_CLASS_LG_LABEL"
          default="smartlink-thumb--lg"
          filter="string"
          showon="use_smartlink_styles:0"
        />
      </fieldset>
    </fields>
  </config>
</extension>
